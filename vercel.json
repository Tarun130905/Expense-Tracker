{
  "version": 2,
  "installCommand": "pip install -r api/requirements.txt",
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" }
  ],
  "functions": {
    "api/**/*.py": {
      "runtime": "python3.11"
    }
  }
}
